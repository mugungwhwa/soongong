#!/usr/bin/env bash
# 순공대장 pre-commit hook
# 잠긴 결정사항 회귀 방지 + 계정 정체성 검증
# 근거: CLAUDE.md §8 폐기 정책 + 글로벌 §6 계정 분리
#
# 활성화: bash scripts/setup-hooks.sh (clone 후 1회)
# 우회: SKIP_PRECOMMIT=1 git commit ...

set -e

RED=$'\033[0;31m'
YEL=$'\033[0;33m'
GRN=$'\033[0;32m'
RST=$'\033[0m'

# ─────────────────────────────────────────────
# 0. 우회 스위치
# ─────────────────────────────────────────────
if [ "${SKIP_PRECOMMIT:-0}" = "1" ]; then
    echo "${YEL}⊘ SKIP_PRECOMMIT=1 — pre-commit hook 우회${RST}"
    exit 0
fi

# ─────────────────────────────────────────────
# 1. 계정 정체성 검증 (회사 계정 차단)
# ─────────────────────────────────────────────
AUTHOR_EMAIL=$(git config user.email 2>/dev/null || echo "")
AUTHOR_NAME=$(git config user.name 2>/dev/null || echo "")

# 회사 계정 패턴 차단 (글로벌 §6.1)
if echo "$AUTHOR_EMAIL $AUTHOR_NAME" | grep -qiE "treenod|company"; then
    echo "${RED}✗ 회사 계정으로 commit 시도 차단${RST}"
    echo "  user.email: $AUTHOR_EMAIL"
    echo "  user.name:  $AUTHOR_NAME"
    echo ""
    echo "  본 repo는 mugungwhwa 개인 트랙 (CLAUDE.md §3, 글로벌 §6.1)."
    echo "  해결: -c 일회용 옵션 사용"
    echo "    git -c user.name='Mike' -c user.email='mikeikhoonkim1208@gmail.com' commit ..."
    exit 1
fi

# ─────────────────────────────────────────────
# 2. Stage된 파일 + diff 수집
# ─────────────────────────────────────────────
STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED" ]; then
    exit 0
fi

# scripts/ 는 hook 자체에 키워드 패턴을 포함하므로 검사 제외
# (회귀는 docs/ 와 코드 영역에서 의미; hook 정의 자체는 self-reference)
ADDED_LINES=$(git diff --cached -U0 --diff-filter=ACM -- ':!scripts/' | grep -E "^\+[^+]" || true)

# ─────────────────────────────────────────────
# 3. 회귀 키워드 검사 (CLAUDE.md §8 폐기 정책)
# ─────────────────────────────────────────────
declare -a PATTERNS=(
    "Dark Study RPG"
    "Dark RPG"
    "다크 네이비"
    "회독마왕"
    "외주 발주"
    "작가 외주"
    "디자이너 외주"
    "토스 결"
    "토스 톤"
)

VIOLATIONS=0
for pattern in "${PATTERNS[@]}"; do
    HITS=$(echo "$ADDED_LINES" | grep -i "$pattern" 2>/dev/null || true)
    if [ -n "$HITS" ]; then
        echo "${YEL}⚠  잠긴 결정사항 회귀 키워드 감지: '${pattern}'${RST}"
        echo "$HITS" | sed 's/^/    /' | head -3
        echo ""
        VIOLATIONS=$((VIOLATIONS + 1))
    fi
done

# ─────────────────────────────────────────────
# 4. .env 파일 commit 차단 (글로벌 §6 보안)
# ─────────────────────────────────────────────
ENV_FILES=$(echo "$STAGED" | grep -E "(^|/)\.env($|\.)" | grep -v "example" || true)
if [ -n "$ENV_FILES" ]; then
    echo "${RED}✗ .env 파일 commit 차단${RST}"
    echo "$ENV_FILES" | sed 's/^/    /'
    echo "  .env.local.example 같은 템플릿만 commit OK."
    exit 1
fi

# ─────────────────────────────────────────────
# 5. 최종 판정
# ─────────────────────────────────────────────
if [ $VIOLATIONS -gt 0 ]; then
    echo "${RED}✗ ${VIOLATIONS}개 회귀 키워드 차단${RST}"
    echo "  근거: CLAUDE.md §8 폐기 정책 — 회귀 금지 항목"
    echo "  의도된 변경이면: SKIP_PRECOMMIT=1 git commit ..."
    exit 1
fi

echo "${GRN}✓ pre-commit 통과${RST} (패턴 ${#PATTERNS[@]}종 + 계정 + .env 검사)"
exit 0
