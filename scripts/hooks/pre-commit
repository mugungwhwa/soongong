#!/usr/bin/env bash
# 순공대장 pre-commit hook
# 잠긴 결정사항 회귀 방지 + 계정 정체성 검증
# 근거: CLAUDE.md §8 폐기 정책 + 글로벌 §6 계정 분리
#
# 활성화: bash scripts/setup-hooks.sh (clone 후 1회)
# 우회: SKIP_PRECOMMIT=1 git commit ...

set -e

RED=$'\033[0;31m'
YEL=$'\033[0;33m'
GRN=$'\033[0;32m'
RST=$'\033[0m'

# ─────────────────────────────────────────────
# 0. 우회 스위치
# ─────────────────────────────────────────────
if [ "${SKIP_PRECOMMIT:-0}" = "1" ]; then
    echo "${YEL}⊘ SKIP_PRECOMMIT=1 — pre-commit hook 우회${RST}"
    exit 0
fi

# ─────────────────────────────────────────────
# 1. 계정 정체성 검증 (회사 계정 차단)
# ─────────────────────────────────────────────
AUTHOR_EMAIL=$(git config user.email 2>/dev/null || echo "")
AUTHOR_NAME=$(git config user.name 2>/dev/null || echo "")

# 회사 계정 패턴 차단 (글로벌 §6.1)
if echo "$AUTHOR_EMAIL $AUTHOR_NAME" | grep -qiE "treenod|company"; then
    echo "${RED}✗ 회사 계정으로 commit 시도 차단${RST}"
    echo "  user.email: $AUTHOR_EMAIL"
    echo "  user.name:  $AUTHOR_NAME"
    echo ""
    echo "  본 repo는 mugungwhwa 개인 트랙 (CLAUDE.md §3, 글로벌 §6.1)."
    echo "  해결: -c 일회용 옵션 사용"
    echo "    git -c user.name='Mike' -c user.email='mikeikhoonkim1208@gmail.com' commit ..."
    exit 1
fi

# ─────────────────────────────────────────────
# 2. Stage된 파일 + diff 수집
# ─────────────────────────────────────────────
STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED" ]; then
    exit 0
fi

# scripts/ 와 CLAUDE.md 는 폐기 정책을 정의·등록하는 자리이므로 검사 제외
# (회귀는 docs/ 와 코드 영역에서 의미; 정의 자체는 self-reference)
ADDED_LINES=$(git diff --cached -U0 --diff-filter=ACM -- ':!scripts/' ':!CLAUDE.md' | grep -E "^\+[^+]" || true)

# ─────────────────────────────────────────────
# 3. 회귀 키워드 검사 (CLAUDE.md §8 폐기 정책)
# ─────────────────────────────────────────────
declare -a PATTERNS=(
    "Dark Study RPG"
    "Dark RPG"
    "다크 네이비"
    "회독마왕"
    "외주 발주"
    "작가 외주"
    "디자이너 외주"
    "토스 결"
    "토스 톤"
)

VIOLATIONS=0
for pattern in "${PATTERNS[@]}"; do
    HITS=$(echo "$ADDED_LINES" | grep -i "$pattern" 2>/dev/null || true)
    if [ -n "$HITS" ]; then
        echo "${YEL}⚠  잠긴 결정사항 회귀 키워드 감지: '${pattern}'${RST}"
        echo "$HITS" | sed 's/^/    /' | head -3
        echo ""
        VIOLATIONS=$((VIOLATIONS + 1))
    fi
done

# ─────────────────────────────────────────────
# 3.5 MULTICA-RUNTIME 자동 주입 블록 차단 (repo SSoT 오염 방지)
# ─────────────────────────────────────────────
# Multica 런타임이 CLAUDE.md 끝에 'do not edit' 런타임 컨텍스트를 주입한다.
# 휘발성(에이전트 identity + issue ID)이므로 정식 문서에 commit되면 안 됨.
RUNTIME_BLOCK=$(git diff --cached --diff-filter=ACM -- ':!scripts/' | grep -E "^\+.*MULTICA-RUNTIME" || true)
if [ -n "$RUNTIME_BLOCK" ]; then
    echo "${RED}✗ MULTICA-RUNTIME 자동 주입 블록 commit 차단${RST}"
    echo "    Multica 런타임이 주입한 'do not edit' 블록입니다 (휘발성)."
    echo "    해당 파일의 <!-- BEGIN MULTICA-RUNTIME --> ~ <!-- END MULTICA-RUNTIME --> 삭제 후 commit."
    exit 1
fi

# ─────────────────────────────────────────────
# 4. .env 파일 commit 차단 (글로벌 §6 보안)
# ─────────────────────────────────────────────
ENV_FILES=$(echo "$STAGED" | grep -E "(^|/)\.env($|\.)" | grep -v "example" || true)
if [ -n "$ENV_FILES" ]; then
    echo "${RED}✗ .env 파일 commit 차단${RST}"
    echo "$ENV_FILES" | sed 's/^/    /'
    echo "  .env.local.example 같은 템플릿만 commit OK."
    exit 1
fi

# ─────────────────────────────────────────────
# 4.5 이미지 폐기어 OCR 검사 (텍스트 grep 사각 보강, SOO-22)
# ─────────────────────────────────────────────
# 텍스트 검사는 PNG/JPG 안에 박힌 글자를 못 본다(Day7 0건 오판 원인).
# staged된 시각 자산 이미지만 OCR로 스캔. tesseract/kor 미설치 시 graceful skip.
ROOT_DIR=$(git rev-parse --show-toplevel 2>/dev/null || echo ".")
if [ -x "$ROOT_DIR/scripts/check-image-deprecated.sh" ]; then
    if ! bash "$ROOT_DIR/scripts/check-image-deprecated.sh" --staged; then
        echo "${RED}✗ 이미지 폐기어 검출 — commit 차단${RST}"
        echo "  근거: CLAUDE.md §8 폐기 정책 (시각 자산 회귀)"
        echo "  의도된 변경이면: SKIP_PRECOMMIT=1 git commit ..."
        exit 1
    fi
fi

# ─────────────────────────────────────────────
# 5. 최종 판정
# ─────────────────────────────────────────────
if [ $VIOLATIONS -gt 0 ]; then
    echo "${RED}✗ ${VIOLATIONS}개 회귀 키워드 차단${RST}"
    echo "  근거: CLAUDE.md §8 폐기 정책 — 회귀 금지 항목"
    echo "  의도된 변경이면: SKIP_PRECOMMIT=1 git commit ..."
    exit 1
fi

echo "${GRN}✓ pre-commit 통과${RST} (패턴 ${#PATTERNS[@]}종 + 이미지 OCR + 계정 + .env 검사)"
exit 0
