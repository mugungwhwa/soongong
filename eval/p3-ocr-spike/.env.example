# P3 OCR Spike 환경변수
# 사용법: 이 파일을 `.env`로 복사한 뒤 키 값 채우기. `.env`는 gitignore됨.

# Claude vision runner용 (Anthropic)
# 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Claude 모델 (기본 = claude-sonnet-4-6, 정확도 더 높이려면 claude-opus-4-7)
CLAUDE_MODEL=claude-sonnet-4-6

# Mathpix runner용 (없으면 mathpix runner skip하고 2종 비교로 진행)
# 발급: https://accounts.mathpix.com/ocr-api (trial)
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# Tesseract.js는 키 불필요 (로컬 wasm)

# 공통 설정
# 한 케이스당 최대 wall-clock (ms). Claude는 vision이라 30s 권장.
CASE_TIMEOUT_MS=30000

# 결정론 시드 (현재 runner들은 외부 API 호출이라 영향 적지만 향후 sampling 추가 시 사용)
SEED=42
