# 순공대장 환경 변수 템플릿
# 이 파일을 apps/web/.env.local 로 복사하고 실제 값을 채워서 사용.
# 절대 git에 commit 하지 말 것 (.gitignore에 이미 포함).
#
# 참조 문서:
# - docs/setup/2026-05-14-environment-decisions.md (결정 가이드)
# - docs/superpowers/plans/2026-05-14-soongong-mvp1-p1-foundation.md (Task 4)

# ─────────────────────────────────────────────
# Supabase (결정 2)
# ─────────────────────────────────────────────
# Supabase Dashboard → Settings → API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# 서버 사이드 전용 (Edge Function / API routes 에서만 사용)
# 절대 NEXT_PUBLIC_ prefix 붙이지 말 것
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ─────────────────────────────────────────────
# Anthropic API (결정 3)
# ─────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# 모델 라우팅 (결정 5 — 변경 시 P3 sub-plan _shared/ai.ts 참조)
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_QUALITY=claude-sonnet-4-6

# ─────────────────────────────────────────────
# Mathpix OCR (결정 4 — 활성 시)
# ─────────────────────────────────────────────
# https://mathpix.com 회원가입 후 API 키 발급
ENABLE_MATHPIX=false
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# ─────────────────────────────────────────────
# App settings
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─────────────────────────────────────────────
# Vercel (Vercel CLI 사용 시 자동 세팅됨)
# ─────────────────────────────────────────────
# VERCEL_ENV=development
# VERCEL_URL=
